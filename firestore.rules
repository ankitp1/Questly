rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ankitp1@gmail.com" && request.auth.token.email_verified == true));
    }

    // Domain Validators
    function isValidUserStats(data) {
      return data.keys().hasAll(['current_points', 'target_goal', 'streak_days']) &&
             data.current_points is int &&
             data.target_goal is int &&
             data.streak_days is int;
    }
    function isValidRule(data) {
      return data.keys().hasAll(['task_name', 'action', 'point_value', 'validation_method']) &&
             data.task_name is string &&
             data.action is string &&
             data.point_value is int &&
             data.validation_method in ['Image', 'Timer', 'Manual'];
    }
    function isValidHistoryItem(data) {
      return data.keys().hasAll(['task', 'points_awarded', 'timestamp', 'status']) &&
             data.task is string &&
             data.points_awarded is int &&
             data.status in ['APPROVED', 'REJECTED'];
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /profile/{profileId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      match /stats/{statId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if (isOwner(userId) && isValidUserStats(request.resource.data)) || isAdmin();
      }

      match /rules/{ruleId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if (isOwner(userId) && isValidRule(request.resource.data)) || isAdmin();
      }

      match /history/{historyId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if (isOwner(userId) && isValidHistoryItem(request.resource.data)) || isAdmin();
      }
    }
  }
}
